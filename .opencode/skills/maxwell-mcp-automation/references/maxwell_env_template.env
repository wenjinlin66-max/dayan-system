# Maxwell MCP runtime configuration (template)

# ANSYS Electronics Desktop root
AEDT_ROOT=D:\Program Files\AnsysEM\v231\Win64

# Suggested executable path (verify locally)
AEDT_EXE=D:\Program Files\AnsysEM\v231\Win64\ansysedt.exe

# Version tag
AEDT_VERSION=2023R1

# Transport mode: grpc | com
AEDT_TRANSPORT=grpc

# Run UI mode: true = no GUI
AEDT_NON_GRAPHICAL=true

# License
ANSYSLMD_LICENSE_FILE=1055@LAPTOP-DGVONA4D
LICENSE_FILE_PATH=C:\Program Files\AnsysEM\v231\Win64\licensingclient\winx64\license.lic

# Outputs
MAXWELL_OUTPUT_DIR=results/maxwell-mcp

# Safety
MAXWELL_EXECUTION_MODE=implement_only
