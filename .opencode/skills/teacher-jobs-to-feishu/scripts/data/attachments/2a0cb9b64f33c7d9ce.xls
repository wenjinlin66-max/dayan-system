ergeDown="1"><Data ss:Type="String">学位要求</Data></Cell><Cell ss:StyleID="s68" ss:MergeDown="1"><Data ss:Type="String">专业要求</Data></Cell><Cell ss:StyleID="s69" ss:MergeDown="1"><Data ss:Type="String">职称等级</Data></Cell><Cell ss:StyleID="s70" ss:MergeDown="1"><Data ss:Type="String">职称系列</Data></Cell><Cell ss:StyleID="s71" ss:MergeDown="1"><Data ss:Type="String">年龄</Data></Cell><Cell ss:StyleID="s72" ss:MergeDown="1"><Data ss:Type="String">工作经历</Data></Cell><Cell ss:StyleID="s73" ss:MergeDown="1"><Data ss:Type="String">其他要求</Data></Cell><Cell ss:StyleID="s74" ss:MergeDown="1"><Data ss:Type="String">考试方式</Data></Cell></Row><Row ss:StyleID="s50" ss:Height="20"/><Row ss:StyleID="s50" ss:Height="140"><Cell ss:StyleID="s54"><Data ss:Type="String">1</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">工学院</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">专任教师</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">从事工学院机械工程系的教学、科研、学科建设、师资队伍建设等相关工作。</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">专业技术岗位七级以上</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">1</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">不限</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">研究生</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">博士</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">(A0802)机械工程&#10;(A0804)仪器科学与技术&#10;(A0827)核科学与技术</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">副高以上</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">工程技术人员,高等学校教师</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">45周岁以下</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">5年</Data></Cell><Cell ss:StyleID="s56"><Data ss:Type="String">业绩具体要求：达到以下2种业绩条件中的1条即可：1、需满足自博士研究生毕业后从事专业技术工作以来，主持1项国家级项目或1项省部级重点项目，且发表P4/B4类以上成果14项以上或发表P4/B4类以上成果6项以上（其中P2/B2类成果4项或P3/B3类成果6项以上)；2、需满足自博士研究生毕业后从事专业技术工作以来，主持2项国家级项目或2项省部级重点项目，且发表P4/B4类以上成果7项以上或发表P4/B4类以上成果3项以上（其中P2/B2类成果2项或P3/B3类成果3项以上)。</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">直接业务考核</Data></Cell></Row><Row ss:StyleID="s50" ss:Height="138"><Cell ss:StyleID="s54"><Data ss:Type="String">2</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">化学化工学院</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">专任教师</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">从事化学化工学院化学系的教学、科研、学科建设、师资队伍建设等相关工作。</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">专业技术岗位七级以上</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">1</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">不限</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">研究生</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">博士</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">(A0703)化学</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">副高以上</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">工程技术人员,高等学校教师</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">45周岁以下</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">5年</Data></Cell><Cell ss:StyleID="s56"><Data ss:Type="String">业绩具体要求：达到以下2种业绩条件中的1条即可：1、需满足自博士研究生毕业后从事专业技术工作以来，主持1项国家级项目或1项省部级重点项目，且发表P4/B4类以上成果14项以上或发表P4/B4类以上成果6项以上（其中P2/B2类成果4项或P3/B3类成果6项以上)；2、需满足自博士研究生毕业后从事专业技术工作以来，主持2项国家级项目或2项省部级重点项目，且发表P4/B4类以上成果7项以上或发表P4/B4类以上成果3项以上（其中P2/B2类成果2项或P3/B3类成果3项以上)。</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">直接业务考核</Data></Cell></Row><Row ss:StyleID="s50" ss:Height="124"><Cell ss:StyleID="s54"><Data ss:Type="String">3</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">长江新闻与传播学院</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">专任教师</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">从事长江新闻与传播学院的教学、科研、学科建设、师资队伍建设等相关工作。</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">专业技术岗位四级以上</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">1</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">不限</Data></Cell><Cell ss:StyleID="s54"><Data ss:Type="String">研究生</Data></Cell><Cell ss:StyleID="s54"><D